<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Enable Threshold -->
            <TextView
                android:id="@+id/tvEnableThresholdLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <SeekBar
                    android:id="@+id/seekEnableThreshold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/etEnableThreshold"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="3"
                    android:gravity="center"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Disable Threshold -->
            <TextView
                android:id="@+id/tvDisableThresholdLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <SeekBar
                    android:id="@+id/seekDisableThreshold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/etDisableThreshold"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="3"
                    android:gravity="center"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Min State Seconds -->
            <TextView
                android:id="@+id/tvMinStateSecondsLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <SeekBar
                    android:id="@+id/seekMinStateSeconds"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/etMinStateSeconds"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="3"
                    android:gravity="center"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Restart button pinned to bottom -->
    <Button
        android:id="@+id/btnRestartService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Apply and Restart Service"
        android:layout_marginTop="8dp" />

</LinearLayout>
